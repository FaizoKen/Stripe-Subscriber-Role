# PostgreSQL password — used by the `db` service in compose.yml AND
# interpolated into DATABASE_URL. Set both halves consistently in prod.
# Generate a fresh value: `openssl rand -base64 24`
POSTGRES_PASSWORD=

# DATABASE_URL templates `${POSTGRES_PASSWORD}` for compose; if you run the
# app outside compose, replace the placeholder with the literal password.
DATABASE_URL=postgres://ssr:${POSTGRES_PASSWORD}@db:5432/stripe_subscriber_role

# Long random HMAC key used to sign session + iframe-session tokens AND to
# derive the KEK that encrypts each connected Stripe restricted API key +
# webhook secret at rest (AES-256-GCM; see services/crypto.rs).
# Generate a fresh value per environment: `openssl rand -base64 48`
SESSION_SECRET=

# Public-facing base URL of this plugin (no trailing slash). Origin must be HTTPS in prod.
BASE_URL=https://your-domain.com/stripe-subscriber-role

LISTEN_ADDR=0.0.0.0:8096

# Auth Gateway integration (required — sync workers call /auth/internal/*).
# Defaults to deriving the origin from BASE_URL if unset. Set explicitly in local dev.
# AUTH_GATEWAY_URL=http://localhost:8090

# Shared secret — must match the Auth Gateway's INTERNAL_API_KEY value.
# Generate: `openssl rand -hex 32`
INTERNAL_API_KEY=

# Base URL of the RoleLogic API. Default: https://api-rolelogic.faizo.net.
# Override per environment (staging, DR region, local replay). No trailing slash.
# ROLELOGIC_API_URL=https://api-rolelogic.faizo.net

# Origin allowed to embed this plugin's role-config page in an iframe (the
# dashboard's origin). Defaults to https://rolelogic.faizo.net when unset.
# RL_DASHBOARD_ORIGIN=https://rolelogic.faizo.net

# --- Stripe -------------------------------------------------------------
# NOTE: There is NO global Stripe key here. Each Discord server connects its
# OWN Stripe account from the role-config UI by pasting a *restricted*
# (read-only) API key — see README. Keys are stored AES-256-GCM encrypted.
# The Stripe API base can be overridden for testing against a mock server.
# STRIPE_API_BASE=https://api.stripe.com

# --- Scaling knobs -------------------------------------------------------

# Number of job-polling worker tasks. Each claims a batch via
# `FOR UPDATE SKIP LOCKED` so this scales linearly until DB-pool saturation.
# WORKER_CONCURRENCY=4

# DB pool sizing. Budget (replicas * DB_MAX_CONNECTIONS) ≤ pgBouncer pool.
# DB_MAX_CONNECTIONS=16
# DB_MIN_CONNECTIONS=2
# DB_ACQUIRE_TIMEOUT_SECS=5
# DB_IDLE_TIMEOUT_SECS=600

# Default keeps app logs at INFO and `tower_http` at WARN.
RUST_LOG=stripe_subscriber_role=info,tower_http=warn
